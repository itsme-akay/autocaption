<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest Version="7.0"
  ExtensionBundleId="com.autocaption.panel"
  ExtensionBundleVersion="1.0.0"
  ExtensionBundleName="AutoCaption">

  <ExtensionList>
    <Extension Id="com.autocaption.panel" Version="1.0.0"/>
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <Host Name="AEFT" Version="[17.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="11.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.autocaption.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./client/index.html</MainPath>
          <ScriptPath>./host/index.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>AutoCaption</Menu>
          <Geometry>
            <Size>
              <Height>580</Height>
              <Width>340</Width>
            </Size>
            <MinSize>
              <Height>480</Height>
              <Width>300</Width>
            </MinSize>
          </Geometry>
          <Icons>
            <Icon Type="Normal">./assets/icon_32.png</Icon>
            <Icon Type="RollOver">./assets/icon_32.png</Icon>
            <Icon Type="DarkNormal">./assets/icon_32.png</Icon>
            <Icon Type="DarkRollOver">./assets/icon_32.png</Icon>
          </Icons>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>

</ExtensionManifest>
